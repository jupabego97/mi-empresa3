{% comment %}Product Page — Brutalista NANO v3.0{% endcomment %}

{%- assign cv = product.selected_or_first_available_variant -%}
{%- unless cv -%}{%- assign cv = product.variants.first -%}{%- endunless -%}

<!-- Breadcrumb -->
<nav class="breadcrumb" aria-label="Breadcrumb">
  <a href="/">INICIO</a>
  <span>/</span>
  {%- if product.collections.first -%}
    <a href="{{ product.collections.first.url }}">{{ product.collections.first.title | upcase }}</a>
    <span>/</span>
  {%- endif -%}
  <span>{{ product.title | upcase | truncate: 40 }}</span>
</nav>

<div class="product-page" data-section-id="{{ section.id }}" itemscope itemtype="https://schema.org/Product">
  <div class="product-page__grid">

    <!-- Gallery -->
    <div class="product-gallery">
      <div class="product-gallery__main">
        {%- if product.featured_media -%}
          <img
            id="product-main-image"
            src="{{ product.featured_media | image_url: width: 900 }}"
            alt="{{ product.featured_media.alt | default: product.title | escape }}"
            loading="eager"
            width="900"
            height="900"
            itemprop="image"
          >
        {%- else -%}
          <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:var(--color-accent);opacity:0.4;">
            <svg width="80" height="80" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
              <rect x="3" y="3" width="18" height="18"/><path d="M3 9h18M9 21V9"/>
            </svg>
          </div>
        {%- endif -%}

        {%- if cv.compare_at_price > cv.price -%}
          {%- assign pct = cv.compare_at_price | minus: cv.price | times: 100 | divided_by: cv.compare_at_price -%}
          <span class="product-card__sale-badge">-{{ pct }}%</span>
        {%- endif -%}
      </div>

      {%- if product.media.size > 1 -%}
        <div class="product-gallery__thumbs">
          {%- for media in product.media limit: 6 -%}
            <button
              class="product-gallery__thumb {% if forloop.first %}active{% endif %}"
              data-src="{{ media | image_url: width: 900 }}"
              aria-label="Ver imagen {{ forloop.index }}"
            >
              <img src="{{ media | image_url: width: 120 }}" alt="{{ media.alt | default: product.title | escape }}" loading="lazy">
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Product info -->
    <div class="product-info" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
      <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}">
      <meta itemprop="price" content="{{ cv.price | money_without_currency | remove: ',' }}">
      <link itemprop="availability" href="{% if cv.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}">

      {%- if product.vendor != blank -%}
        <p class="product-info__vendor" itemprop="brand">{{ product.vendor | upcase }}</p>
      {%- endif -%}

      <h1 class="product-info__title" itemprop="name">{{ product.title | upcase }}</h1>

      <p class="product-info__price">
        {{ cv.price | money }}
        {%- if cv.compare_at_price > cv.price -%}
          <s>{{ cv.compare_at_price | money }}</s>
        {%- endif -%}
      </p>

      {%- form 'product', product, id: 'product-form-{{ section.id }}' -%}
        <input type="hidden" name="id" id="variant-id" value="{{ cv.id }}">

        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div style="margin-bottom:16px;">
              <label class="product-form__label">{{ option.name | upcase }}</label>
              <select
                class="product-form__select"
                name="options[{{ option.name }}]"
                data-option-index="{{ forloop.index0 }}"
              >
                {%- for value in option.values -%}
                  <option value="{{ value }}" {% if option.selected_value == value %}selected{% endif %}>
                    {{ value }}
                  </option>
                {%- endfor -%}
              </select>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <label class="product-form__label">CANTIDAD</label>
        <div class="product-form__qty" style="margin-bottom:20px;">
          <button type="button" class="product-form__qty-btn product-form__qty-decrease" aria-label="Reducir">&#8722;</button>
          <input type="number" name="quantity" value="1" min="1" class="product-form__qty-input" aria-label="Cantidad">
          <button type="button" class="product-form__qty-btn product-form__qty-increase" aria-label="Aumentar">&#43;</button>
        </div>

        <button
          type="submit"
          name="add"
          class="product-form__add-btn"
          id="add-to-cart-btn"
          {% unless cv.available %}disabled{% endunless %}
        >
          {%- if cv.available -%}+ AGREGAR AL CARRITO{%- else -%}AGOTADO{%- endif -%}
        </button>

        {%- if section.settings.show_buy_now and cv.available -%}
          <button
            type="submit"
            name="checkout"
            style="width:100%;background:transparent;border:var(--border);color:var(--color-accent);font-family:var(--font-mono);font-size:13px;font-weight:700;text-transform:uppercase;padding:12px;cursor:pointer;margin-bottom:16px;transition:var(--transition);"
            onmouseover="this.style.background='var(--color-accent)';this.style.color='white';"
            onmouseout="this.style.background='transparent';this.style.color='var(--color-accent)';"
          >
            COMPRAR AHORA
          </button>
        {%- endif -%}
      {%- endform -%}

      <!-- Stock status -->
      <p style="font-family:var(--font-mono);font-size:12px;color:{% if cv.available %}var(--color-accent){% else %}var(--color-red){% endif %};margin-bottom:16px;">
        &gt; {% if cv.available %}EN STOCK — LISTO PARA ENVIAR{% else %}AGOTADO TEMPORALMENTE{% endif %}
      </p>

      <!-- Trust bar -->
      <div style="border:var(--border);background:var(--color-card-bg);padding:16px;display:flex;flex-direction:column;gap:8px;">
        <p style="font-family:var(--font-mono);font-size:11px;color:var(--color-text);">&#9899; ENVÍO GRATIS en pedidos +$100.000</p>
        <p style="font-family:var(--font-mono);font-size:11px;color:var(--color-text);">&#9899; GARANTÍA DIRECTA 6 meses</p>
        <p style="font-family:var(--font-mono);font-size:11px;color:var(--color-text);">&#9899; DEVOLUCIONES FÁCILES en 30 días</p>
      </div>

      {%- if product.description != blank -%}
        <div class="product-info__description">{{ product.description }}</div>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const productData = {{ product | json }};
  const variantIdInput = document.getElementById('variant-id');
  const addBtn = document.getElementById('add-to-cart-btn');

  // Quantity buttons
  const qtyInput = document.querySelector('.product-form__qty-input');
  document.querySelector('.product-form__qty-decrease')?.addEventListener('click', function() {
    if (qtyInput) qtyInput.value = Math.max(1, parseInt(qtyInput.value || 1) - 1);
  });
  document.querySelector('.product-form__qty-increase')?.addEventListener('click', function() {
    if (qtyInput) qtyInput.value = parseInt(qtyInput.value || 1) + 1;
  });

  // Variant selector
  const selects = document.querySelectorAll('[data-option-index]');
  function updateVariant() {
    const options = [];
    selects.forEach(sel => { options[parseInt(sel.dataset.optionIndex)] = sel.value; });
    const variant = productData.variants.find(v =>
      options.every((opt, i) => v['option' + (i+1)] === opt)
    );
    if (variant && variantIdInput) {
      variantIdInput.value = variant.id;
      if (addBtn) {
        addBtn.disabled = !variant.available;
        addBtn.textContent = variant.available ? '+ AGREGAR AL CARRITO' : 'AGOTADO';
      }
      const priceEl = document.querySelector('.product-info__price');
      if (priceEl && variant.price) {
        const fmt = new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', minimumFractionDigits: 0 });
        let html = fmt.format(variant.price / 100);
        if (variant.compare_at_price && variant.compare_at_price > variant.price) {
          html += ` <s>${fmt.format(variant.compare_at_price / 100)}</s>`;
        }
        priceEl.innerHTML = html;
      }
      const url = new URL(window.location);
      url.searchParams.set('variant', variant.id);
      window.history.replaceState({}, '', url);
    }
  }
  selects.forEach(sel => sel.addEventListener('change', updateVariant));
});
</script>

{% schema %}
{
  "name": "Producto",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_buy_now",
      "label": "Mostrar botón Comprar Ahora",
      "default": true
    }
  ]
}
{% endschema %}
