{%- paginate collection.products by section.settings.products_per_page -%}

<!-- Collection header -->
<div class="collection-header">
  <h1 class="collection-header__title">{{ collection.title | upcase }}</h1>
  {%- if collection.description != blank -%}
    <p class="collection-header__desc">{{ collection.description | strip_html | truncate: 180 }}</p>
  {%- endif -%}
</div>

<!-- Toolbar -->
<div class="collection-toolbar">
  <p class="collection-toolbar__info">{{ collection.products_count }} PRODUCTOS</p>
  <div style="display:flex;gap:10px;align-items:center;">
    <label for="sort-select" class="visually-hidden">Ordenar</label>
    <select id="sort-select" class="collection-toolbar__sort" onchange="window.location.href=this.value">
      {%- for option in collection.sort_options -%}
        <option value="{{ option.url }}" {% if option.value == collection.sort_by %}selected{% endif %}>
          {{ option.name | upcase }}
        </option>
      {%- endfor -%}
    </select>
  </div>
</div>

<!-- Product grid -->
<div class="product-section" data-section-id="{{ section.id }}">
  {%- if collection.products.size > 0 -%}
    <div class="product-grid">
      {%- for product in collection.products -%}
        {%- assign obj_num = forloop.index -%}
        <article class="product-card">
          <div class="product-card__image-wrap">
            {%- if product.featured_media -%}
              <img
                class="product-card__image"
                src="{{ product.featured_media | image_url: width: 600 }}"
                alt="{{ product.featured_media.alt | default: product.title | escape }}"
                loading="lazy"
                width="600"
                height="600"
              >
            {%- else -%}
              <div class="product-card__placeholder" aria-hidden="true">
                <svg width="56" height="56" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
                  <rect x="3" y="3" width="18" height="18"/><path d="M3 9h18M9 21V9"/>
                </svg>
              </div>
            {%- endif -%}
            <span class="product-card__badge">SYS.OBJ.{{ obj_num }}</span>
            {%- if product.compare_at_price > product.price -%}
              {%- assign pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
              <span class="product-card__sale-badge">-{{ pct }}%</span>
            {%- endif -%}
          </div>

          <div class="product-card__body">
            <a href="{{ product.url }}">
              <h3 class="product-card__title">{{ product.title }}</h3>
            </a>

            {%- if product.tags.size > 0 -%}
              <ul class="product-card__specs">
                {%- for tag in product.tags limit: 3 -%}
                  <li class="product-card__spec">{{ tag }}</li>
                {%- endfor -%}
              </ul>
            {%- else -%}
              <div style="flex:1;"></div>
            {%- endif -%}

            <p class="product-card__price">
              {{ product.price | money }}
              {%- if product.compare_at_price > product.price -%}
                <s>{{ product.compare_at_price | money }}</s>
              {%- endif -%}
            </p>

            {%- if product.available -%}
              {%- if product.variants.size == 1 -%}
                <form action="/cart/add" method="post">
                  <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                  <input type="hidden" name="quantity" value="1">
                  <button type="submit" class="product-card__btn">+ AGREGAR</button>
                </form>
              {%- else -%}
                <a href="{{ product.url }}" class="product-card__btn">VER OPCIONES</a>
              {%- endif -%}
            {%- else -%}
              <button class="product-card__btn" disabled>AGOTADO</button>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <nav class="pagination" aria-label="Paginación">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}" class="pagination__btn">&larr;</a>
        {%- endif -%}
        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}
            <a href="{{ part.url }}" class="pagination__btn">{{ part.title }}</a>
          {%- elsif part.title == paginate.current_page -%}
            <span class="pagination__btn active" aria-current="page">{{ part.title }}</span>
          {%- else -%}
            <span class="pagination__btn" style="opacity:0.4;">{{ part.title }}</span>
          {%- endif -%}
        {%- endfor -%}
        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}" class="pagination__btn">&rarr;</a>
        {%- endif -%}
      </nav>
    {%- endif -%}

  {%- else -%}
    <div style="padding:64px 0; text-align:center;">
      <p style="font-family:var(--font-mono); color:var(--color-gray);">&gt; No se encontraron productos en esta colección.</p>
      <a href="{{ routes.all_products_collection_url }}" class="hero__cta" style="display:inline-flex;margin-top:24px;">VER TODO</a>
    </div>
  {%- endif -%}
</div>

{%- endpaginate -%}

{% schema %}
{
  "name": "Colección Principal",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 12,
      "label": "Productos por página"
    }
  ]
}
{% endschema %}
