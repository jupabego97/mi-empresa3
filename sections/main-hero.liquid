{% comment %}Hero - NANO Front 2026{% endcomment %}

<section class="hero" data-section-id="{{ section.id }}">
  <div class="hero__box">
    <div class="hero__rating" aria-label="Calificacion 4.9 de 5">
      {%- for i in (1..5) -%}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="m12 2.5 2.9 5.88 6.49.94-4.7 4.57 1.11 6.46L12 17.3 6.2 20.35l1.11-6.46-4.7-4.57 6.49-.94L12 2.5z"/>
        </svg>
      {%- endfor -%}
      <span>4.9/5 PROMEDIO</span>
    </div>

    <h1 class="hero__title">
      {%- if section.settings.title != blank -%}
        {{ section.settings.title }}
      {%- else -%}
        AL SON DE LA <br><span>TECNOLOGIA.</span>
      {%- endif -%}
    </h1>

    <div class="hero__subtitle">
      {%- if section.settings.subtitle != blank -%}
        {%- assign lines = section.settings.subtitle | newline_to_br | split: '<br />' -%}
        {%- for line in lines -%}
          {%- assign clean_line = line | strip_html | strip -%}
          {%- if clean_line != blank -%}
            <p>{{ clean_line }}</p>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <p>Computadores, tablets, parlantes y accesorios con garantia comprobada.</p>
        <p>Compra facil y segura desde cualquier lugar de Colombia.</p>
      {%- endif -%}
    </div>

    <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="hero__cta">
      {{ section.settings.cta_label | default: 'VER OFERTAS FLASH' }}
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "AL SON DE LA TECNOLOGIA."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitulo (lineas separadas)",
      "default": "Computadores, tablets, parlantes y accesorios con garantia comprobada.\nCompra facil y segura desde cualquier lugar de Colombia."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del boton CTA",
      "default": "VER OFERTAS FLASH"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "URL del boton CTA"
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "category": "Hero"
    }
  ]
}
{% endschema %}
