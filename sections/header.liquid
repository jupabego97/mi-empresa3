{% comment %}Header - NANO Clean v4.0{% endcomment %}

<header class="site-header" role="banner">
  <div class="site-header__left">
    <button class="mobile-menu-btn" aria-label="Abrir menu" aria-controls="mobile-menu" aria-expanded="false">
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M3 6h18M3 12h18M3 18h18"/>
      </svg>
    </button>

    <a href="/" class="site-header__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 300 }}"
          alt="{{ shop.name }}"
          width="{{ section.settings.logo_width | default: 120 }}"
          height="44"
          loading="eager"
        >
      {%- else -%}
        <span class="site-header__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>
  </div>

  <div class="site-header__actions">
    <button class="cart-toggle-btn" aria-label="Abrir carrito" aria-haspopup="dialog">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      <span>Carrito (<span data-cart-count>{{ cart.item_count }}</span>)</span>
    </button>
  </div>
</header>

<div class="mobile-menu__backdrop" id="mobile-backdrop"></div>
<nav id="mobile-menu" class="mobile-menu" aria-label="Menu movil" aria-hidden="true">
  <button class="mobile-menu__close" aria-label="Cerrar menu">&times;</button>
  <div class="mobile-menu__nav">
    <a href="/" class="mobile-menu__link">Inicio</a>
    <a href="/collections/all" class="mobile-menu__link">Catálogo</a>
    <a href="/cart" class="mobile-menu__link">Carrito ({{ cart.item_count }})</a>
    {%- if section.settings.whatsapp_number != blank -%}
      <a href="https://wa.me/{{ section.settings.whatsapp_number }}" class="mobile-menu__link" target="_blank" rel="noopener">Contacto</a>
    {%- endif -%}
  </div>
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Ancho del logo (px)",
      "min": 60,
      "max": 260,
      "step": 10,
      "default": 120
    },
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "Numero WhatsApp (sin +)",
      "placeholder": "573001234567"
    }
  ]
}
{% endschema %}
