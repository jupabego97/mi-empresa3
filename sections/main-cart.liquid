{% comment %}Cart Page — Brutalista NANO v3.0{% endcomment %}

<div class="cart-page template-cart" data-section-id="{{ section.id }}">
  <h1 class="cart-page__title">
    TERMINAL DE COMPRA
    {%- if cart.item_count > 0 -%}
      <span style="font-family:var(--font-mono);font-size:14px;color:var(--color-gray);margin-left:12px;">[{{ cart.item_count }} items]</span>
    {%- endif -%}
  </h1>

  {%- if cart.item_count > 0 -%}
    <div class="cart-page__layout">
      <!-- Items -->
      <div>
        <form action="{{ routes.cart_url }}" method="post" id="cart-form">
          {%- for item in cart.items -%}
            <div class="cart-item" data-cart-item data-line="{{ forloop.index }}">
              <a href="{{ item.url }}">
                {%- if item.image -%}
                  <img
                    class="cart-item__image"
                    src="{{ item.image | image_url: width: 200 }}"
                    alt="{{ item.title | escape }}"
                    loading="lazy"
                    width="120"
                    height="120"
                  >
                {%- else -%}
                  <div class="cart-item__image" style="display:flex;align-items:center;justify-content:center;color:var(--color-accent);opacity:0.3;">
                    <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18"/></svg>
                  </div>
                {%- endif -%}
              </a>

              <div class="cart-item__info">
                <p class="cart-item__title">
                  <a href="{{ item.url }}" style="color:inherit;">{{ item.product.title | upcase }}</a>
                </p>
                {%- unless item.product.has_only_default_variant -%}
                  <p class="cart-item__variant">{{ item.variant.title }}</p>
                {%- endunless -%}
                <p class="cart-item__price">{{ item.final_price | money }}</p>

                <div class="cart-item__qty">
                  <button type="button" class="cart-item__qty-btn" data-action="decrease" aria-label="Reducir">&#8722;</button>
                  <input
                    type="number"
                    name="updates[]"
                    value="{{ item.quantity }}"
                    min="0"
                    data-line="{{ forloop.index }}"
                    class="cart-item__qty-val"
                    aria-label="Cantidad"
                    style="width:36px;height:22px;text-align:center;border:1px solid var(--color-accent);border-left:none;border-right:none;font-family:var(--font-mono);font-size:13px;font-weight:700;background:transparent;"
                  >
                  <button type="button" class="cart-item__qty-btn" data-action="increase" aria-label="Aumentar">&#43;</button>
                </div>
              </div>

              <div class="cart-item__actions">
                <button type="button" class="cart-item__remove" data-action="remove" aria-label="Eliminar">&times;</button>
                <span style="font-family:var(--font-mono);font-size:14px;font-weight:700;color:var(--color-accent);">{{ item.final_line_price | money }}</span>
              </div>
            </div>
          {%- endfor -%}
        </form>
      </div>

      <!-- Summary sidebar -->
      <div class="cart-page__summary">
        <h2 class="cart-page__summary-title">RESUMEN DEL PEDIDO</h2>

        <div class="cart-page__summary-row">
          <span>SUBTOTAL</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <div class="cart-page__summary-row" style="color:var(--color-gray);font-size:11px;">
          <span>ENVÍO</span>
          <span>Calculado en checkout</span>
        </div>

        {%- if cart.total_discount > 0 -%}
          <div class="cart-page__summary-row" style="color:#16A34A;">
            <span>DESCUENTO</span>
            <span>-{{ cart.total_discount | money }}</span>
          </div>
        {%- endif -%}

        <div class="cart-page__summary-total">
          <span>TOTAL</span>
          <span>{{ cart.total_price | money }}</span>
        </div>

        <button type="submit" name="checkout" form="cart-form" class="cart-page__checkout-btn">
          PROCESAR PAGO
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>

        <a href="/collections/all" style="display:block;text-align:center;font-family:var(--font-mono);font-size:12px;color:var(--color-accent);margin-top:12px;text-decoration:underline;">
          &larr; SEGUIR COMPRANDO
        </a>

        <p style="font-family:var(--font-mono);font-size:10px;text-align:center;color:var(--color-gray);margin-top:16px;text-transform:uppercase;">
          &#128274; PAGO SEGURO CIFRADO POR SHOPIFY
        </p>

        {%- if shop.enabled_payment_types.size > 0 -%}
          <div style="display:flex;justify-content:center;gap:6px;flex-wrap:wrap;margin-top:12px;opacity:0.6;">
            {%- for type in shop.enabled_payment_types -%}
              {{ type | payment_type_svg_tag: class: 'payment-icon' }}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

  {%- else -%}
    <div style="text-align:center;padding:64px 0;">
      <div style="font-size:48px;opacity:0.4;color:var(--color-accent);margin-bottom:16px;">&#9783;</div>
      <p style="font-family:var(--font-mono);font-size:16px;color:var(--color-accent);font-weight:700;margin-bottom:8px;">&gt; CARRITO_VACÍO</p>
      <p style="font-family:var(--font-mono);font-size:12px;color:var(--color-gray);margin-bottom:32px;">Añade productos para continuar.</p>
      <a href="/collections/all" class="hero__cta">
        EXPLORAR INVENTARIO
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  {%- endif -%}
</div>

<style>
  .payment-icon { height: 22px; width: auto; }
</style>

<script>
(function() {
  if (window.__cartPageInit) return;
  window.__cartPageInit = true;

  let busy = false;

  async function updateLine(line, qty) {
    if (busy) return;
    busy = true;
    const row = document.querySelector('[data-line="' + line + '"]');
    if (row) row.style.opacity = '0.4';
    try {
      const res = await fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line: parseInt(line), quantity: Math.max(0, parseInt(qty)) })
      });
      if (res.ok) window.location.reload();
      else { busy = false; if (row) row.style.opacity = '1'; }
    } catch(e) { busy = false; if (row) row.style.opacity = '1'; }
  }

  document.addEventListener('click', function(e) {
    if (busy) return;
    const btn = e.target.closest('[data-action]');
    if (!btn) return;
    const item = btn.closest('[data-line]');
    if (!item) return;
    e.preventDefault();
    const line = item.dataset.line;
    const input = item.querySelector('input[name="updates[]"]');
    const val = parseInt(input?.value || 0);
    if (btn.dataset.action === 'increase') updateLine(line, val + 1);
    else if (btn.dataset.action === 'decrease') updateLine(line, val - 1);
    else if (btn.dataset.action === 'remove') updateLine(line, 0);
  }, true);
})();
</script>

{% schema %}
{
  "name": "Carrito",
  "settings": []
}
{% endschema %}
